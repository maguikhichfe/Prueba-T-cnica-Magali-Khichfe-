# ── OpenAI ────────────────────────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=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

# Modelo a usar (gpt-3.5-turbo es la capa gratuita/económica)
