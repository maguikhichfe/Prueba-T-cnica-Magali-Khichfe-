# Timeout en segundos para llamadas a OpenAI
OPENAI_TIMEOUT=30

# ── Python API ────────────────────────────────────────────────────────────────
# Puerto donde escucha el servidor Flask
PYTHON_API_PORT=8000

# Máximo de caracteres de contexto enviados al LLM
MAX_CONTEXT_CHARS=3000

# ── n8n ───────────────────────────────────────────────────────────────────────
# Puerto donde corre n8n (por defecto 5678)
N8N_PORT=5678
